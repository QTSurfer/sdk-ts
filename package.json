{
  "name": "@qtsurfer/sdk",
  "version": "0.1.2",
  "description": "Opinionated TypeScript SDK for QTSurfer: workflow orchestration, domain objects, normalized errors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QTSurfer/sdk-ts.git"
  },
  "bugs": {
    "url": "https://github.com/QTSurfer/sdk-ts/issues"
  },
  "homepage": "https://github.com/QTSurfer/sdk-ts#readme",
  "author": "QTSurfer (https://github.com/QTSurfer)",
  "license": "Apache-2.0",
  "keywords": [
    "qtsurfer",
    "sdk",
    "typescript",
    "backtesting",
    "trading",
    "workflow"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@qtsurfer/api-client": "^0.1.1",
    "cockatiel": "^3.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
